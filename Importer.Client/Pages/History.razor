@page "/history"
@using Importer.Client.Models
@inject Importer.Client.Services.IndexedDbService IndexedDb
@inject Importer.Client.Services.SyncService SyncService
@inject NavigationManager Nav

<h3>Histórico</h3>

@if (_loading)
{
    <p><em>A carregar…</em></p>
}
else if (_docs.Count == 0)
{
    <p><em>Sem documentos.</em></p>
}
else
{
    <fieldset style="margin-bottom:12px; padding:12px; border:1px solid #ddd; border-radius:8px;">
        <legend style="padding:0 6px; font-weight:600;">Filtros</legend>

        <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(180px, 1fr)); gap:8px; align-items:end;">
            <div>
                <label>Estado</label>
                <select @bind="_statusFilter" style="width:100%;">
                    <option value="">Todos</option>
                    @foreach (var s in _statusValues)
                    {
                        <option value="@s">@s</option>
                    }
                </select>
            </div>

            <div>
                <label>Data inicial</label>
                <input type="date" @bind="_fromDate" style="width:100%;" />
            </div>

            <div>
                <label>Data final</label>
                <input type="date" @bind="_toDate" style="width:100%;" />
            </div>

            <div>
                <label>NIF</label>
                <input @bind="_nifFilter" @bind:event="oninput" placeholder="Ex: 509123456" style="width:100%;" />
            </div>

            <div>
                <label>Série/Número</label>
                <input @bind="_seriesNumberFilter" @bind:event="oninput" placeholder="Ex: FT 1/23" style="width:100%;" />
            </div>

            <div>
                <label>ATCUD</label>
                <input @bind="_atcudFilter" @bind:event="oninput" placeholder="Ex: ABCD-123" style="width:100%; font-family:monospace;" />
            </div>

            <div style="display:flex; gap:6px; flex-wrap:wrap;">
                <button type="button" @onclick="ClearFilters">Limpar filtros</button>
                <button type="button" @onclick="TrySyncNowAsync" disabled="@_busySync">Sync agora</button>
            </div>
        </div>
    </fieldset>

    @if (FilteredDocs.Count == 0)
    {
        <p><em>Sem resultados para os filtros atuais.</em></p>
    }
    else
    {
        <table class="table" style="width:100%;">
            <thead>
            <tr>
                <th>Data doc.</th>
                <th>Tipo</th>
                <th>Emitente</th>
                <th>ATCUD</th>
                <th>Série/Nº</th>
                <th>Estado</th>
                <th>Detalhe Sync</th>
                <th></th>
            </tr>
            </thead>
            <tbody>
            @foreach (var d in FilteredDocs)
            {
                _outboxByDoc.TryGetValue(d.Id, out var outbox);

                <tr>
                    <td>@(d.DocumentDate == default ? "-" : d.DocumentDate.ToLocalTime().ToString("yyyy-MM-dd"))</td>
                    <td>@(string.IsNullOrWhiteSpace(d.DocumentType) ? "-" : d.DocumentType)</td>

                    <td>
                        @if (!string.IsNullOrWhiteSpace(d.IssuerName))
                        {
                            <div>@d.IssuerName</div>
                            <div style="opacity:.7; font-size:12px;">NIF: @d.IssuerTaxId</div>
                        }
                        else
                        {
                            <span>@(string.IsNullOrWhiteSpace(d.IssuerTaxId) ? "-" : d.IssuerTaxId)</span>
                        }
                    </td>

                    <td style="font-family: monospace;">@(string.IsNullOrWhiteSpace(d.ATCUD) ? "-" : d.ATCUD)</td>
                    <td>@(string.IsNullOrWhiteSpace(d.Series) && string.IsNullOrWhiteSpace(d.DocumentNumber) ? "-" : $"{d.Series}/{d.DocumentNumber}")</td>
                    <td>@d.SyncStatus</td>

                    <td style="max-width:260px; font-size:12px;">
                        @if (outbox is null)
                        {
                            <span style="opacity:.7;">Sem item na outbox</span>
                        }
                        else
                        {
                            <div>Tentativas: <b>@outbox.AttemptCount</b></div>
                            <div>Próxima: @outbox.NextAttemptAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                            @if (!string.IsNullOrWhiteSpace(outbox.LastError))
                            {
                                <div style="color:#a33;">Erro: @outbox.LastError</div>
                            }
                            @if (outbox.IsPermanentError)
                            {
                                <div style="color:#a33;">Erro permanente</div>
                            }
                        }
                    </td>

                    <td style="text-align:right; white-space:nowrap;">
                        @if (outbox is not null)
                        {
                            <button type="button" @onclick="() => RetryDocAsync(d.Id)" disabled="@_busySync">Repetir sync</button>
                        }
                        <button @onclick="() => Open(d.Id)">Ver</button>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
}

@code {
    private bool _loading = true;
    private bool _busySync;

    private readonly List<LocalDocument> _docs = new();
    private readonly Dictionary<Guid, OutboxItem> _outboxByDoc = new();

    private readonly string[] _statusValues = Enum.GetNames<SyncStatus>();

    private string _statusFilter = string.Empty;
    private string _nifFilter = string.Empty;
    private string _seriesNumberFilter = string.Empty;
    private string _atcudFilter = string.Empty;
    private DateTime? _fromDate;
    private DateTime? _toDate;

    private List<LocalDocument> FilteredDocs => _docs
        .Where(MatchStatus)
        .Where(MatchDateRange)
        .Where(MatchNif)
        .Where(MatchSeriesNumber)
        .Where(MatchAtcud)
        .ToList();

    private void Open(Guid id) => Nav.NavigateTo($"/validate/{id}");

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    /// <summary>
    /// Carrega documentos + estado da outbox para o ecrã ficar explicativo.
    /// </summary>
    private async Task LoadAsync()
    {
        _loading = true;

        _docs.Clear();
        _docs.AddRange(await IndexedDb.GetAllDocumentsAsync());

        _outboxByDoc.Clear();
        var outbox = await IndexedDb.GetAllOutboxAsync();
        foreach (var item in outbox)
            _outboxByDoc[item.DocumentId] = item;

        _loading = false;
    }

    /// <summary>
    /// Tenta sincronização global imediata e refresca o estado apresentado.
    /// </summary>
    private async Task TrySyncNowAsync()
    {
        if (_busySync) return;
        _busySync = true;
        try
        {
            await SyncService.SyncPendingAsync();
            await LoadAsync();
        }
        finally
        {
            _busySync = false;
        }
    }

    /// <summary>
    /// Força reenvio de um documento com erro (incluindo erro permanente) e tenta sync.
    /// </summary>
    private async Task RetryDocAsync(Guid id)
    {
        if (_busySync) return;
        _busySync = true;
        try
        {
            await IndexedDb.ForceRetryOutboxAsync(id);
            await SyncService.SyncPendingAsync();
            await LoadAsync();
        }
        finally
        {
            _busySync = false;
        }
    }

    private bool MatchStatus(LocalDocument d)
        => string.IsNullOrWhiteSpace(_statusFilter) || d.SyncStatus.ToString().Equals(_statusFilter, StringComparison.OrdinalIgnoreCase);

    private bool MatchDateRange(LocalDocument d)
    {
        if (d.DocumentDate == default)
            return _fromDate is null && _toDate is null;

        var day = d.DocumentDate.Date;

        if (_fromDate is not null && day < _fromDate.Value.Date)
            return false;

        if (_toDate is not null && day > _toDate.Value.Date)
            return false;

        return true;
    }

    private bool MatchNif(LocalDocument d)
        => string.IsNullOrWhiteSpace(_nifFilter)
           || (d.IssuerTaxId?.Contains(_nifFilter.Trim(), StringComparison.OrdinalIgnoreCase) ?? false);

    private bool MatchSeriesNumber(LocalDocument d)
    {
        if (string.IsNullOrWhiteSpace(_seriesNumberFilter))
            return true;

        var q = _seriesNumberFilter.Trim();
        var composed = $"{d.Series}/{d.DocumentNumber}";

        return (d.Series?.Contains(q, StringComparison.OrdinalIgnoreCase) ?? false)
               || (d.DocumentNumber?.Contains(q, StringComparison.OrdinalIgnoreCase) ?? false)
               || composed.Contains(q, StringComparison.OrdinalIgnoreCase);
    }

    private bool MatchAtcud(LocalDocument d)
        => string.IsNullOrWhiteSpace(_atcudFilter)
           || (d.ATCUD?.Contains(_atcudFilter.Trim(), StringComparison.OrdinalIgnoreCase) ?? false);

    private void ClearFilters()
    {
        _statusFilter = string.Empty;
        _nifFilter = string.Empty;
        _seriesNumberFilter = string.Empty;
        _atcudFilter = string.Empty;
        _fromDate = null;
        _toDate = null;
    }
}
