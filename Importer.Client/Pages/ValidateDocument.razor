@page "/validate/{DocumentId:guid?}"
@using Importer.Client.Services
@using Importer.Core.QR
@using Importer.Client.Models
@using System.Text.Json
@inject IndexedDbService IndexedDb
@inject SyncService SyncService
@inject DocumentStateService DocumentState
@inject NavigationManager Nav
@inject QrDecodeService QrDecoder

<PageTitle>Validar Documento</PageTitle>

<div class="validate-layout">

    <details open>
        <summary><b>Documento</b></summary>

        <DocumentPreview FileBytes="@DocumentState.FileBytes"
                         ContentType="@DocumentState.ContentType"
                         FileName="@DocumentState.FileName" />
    </details>

    <ValidationForm @key="_formKey" Model="@_doc" Disabled="@_saving" OnFieldEdited="OnFieldEditedAsync" />

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="alert">@_message</div>
    }

    <div class="actions">
        <button @onclick="SaveDraftAsync" disabled="@_saving">Guardar rascunho</button>
        <button disabled="@_saving">Validar</button>

        @if (!_readingQr)
        {
            <button @onclick="ReprocessQrAsync" disabled="@_saving">
                Reprocessar QR
            </button>
        }
        else
        {
            <button @onclick="CancelQrAsync" type="button">
                Cancelar leitura
            </button>
        }
    </div>


    @if (DocumentState.ContentType?.StartsWith("image/", StringComparison.OrdinalIgnoreCase) == true)
    {
        <details style="margin-top:10px;">
            <summary><b>Fallback manual (Crop QR)</b></summary>
            <p style="margin:8px 0;">Define a área em percentagem da imagem (0-100) e tenta reprocessar só esse recorte.</p>
            <div style="display:grid; grid-template-columns:repeat(4, minmax(110px, 1fr)); gap:8px; max-width:620px;">
                <label>X %<input type="number" min="0" max="100" step="1" @bind="_cropXPct" /></label>
                <label>Y %<input type="number" min="0" max="100" step="1" @bind="_cropYPct" /></label>
                <label>Largura %<input type="number" min="1" max="100" step="1" @bind="_cropWPct" /></label>
                <label>Altura %<input type="number" min="1" max="100" step="1" @bind="_cropHPct" /></label>
            </div>
            <div style="margin-top:8px;">
                <button type="button" @onclick="ReprocessQrCropAsync" disabled="@(_saving || _readingQr)">Reprocessar QR (Crop)</button>
            </div>
        </details>
    }

    @if (!string.IsNullOrWhiteSpace(QrDecodedText))
    {
        <hr />
        <h3>QR lido</h3>

        <details open>
            <summary>Texto do QR (raw)</summary>
            <pre style="white-space:pre-wrap;">@QrDecodedText</pre>
        </details>

        @if (!string.IsNullOrWhiteSpace(QrJson))
        {
            <details open>
                <summary>JSON (serializado)</summary>
                <pre style="white-space:pre-wrap;">@QrJson</pre>
            </details>
        }
    }

    <canvas id="pdfCanvas" style="display:none;"></canvas>
</div>

@code {
    [Parameter] public Guid? DocumentId { get; set; }

    private string? QrDecodedText;
    private string? QrJson;
    private List<QrData> QrDocs = new();

    private bool _saving;
    private bool _readingQr;
    private string? _message;

    private int _formKey = 0;
    private string? _lastAutoSig;

    private CancellationTokenSource? _qrCts;
    private int _qrRunId = 0;
    private bool _loadedFromHistory;

    private double _cropXPct = 55;
    private double _cropYPct = 55;
    private double _cropWPct = 40;
    private double _cropHPct = 40;

    private async Task CancelQrAsync()
    {
        if (!_readingQr) return;

        _qrRunId++;          // invalida esta run imediatamente
        _qrCts?.Cancel();
        _qrCts = null;

        _readingQr = false;
        _message = "Leitura cancelada.";
        await InvokeAsync(StateHasChanged);
    }

    private LocalDocument _doc = new()
    {
        Id = Guid.NewGuid(),
        Source = "Upload",
        SyncStatus = SyncStatus.PendingSync,
        DocumentDate = DateTime.UtcNow
    };

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrWhiteSpace(DocumentState.QrText))
        {
            var qr = DocumentState.QrText;

            QrDecodedText = qr;
            _doc.QrRawPayload = qr;

            RunQrParseAndApply(qr);

            DocumentState.ClearQrText();
            _loadedFromHistory = false;
            return;
        }

        if (DocumentId is not null)
        {
            DocumentState.Clear();

            var doc = await IndexedDb.GetDocumentAsync(DocumentId.Value);
            if (doc is null)
            {
                Nav.NavigateTo("/history");
                return;
            }

            _doc = doc;
            _loadedFromHistory = true;

            if (DocumentState.FileBytes is null)
            {
                var file = await IndexedDb.GetFileAsync(doc.FileKey);
                if (file is null)
                {
                    Nav.NavigateTo("/history");
                    return;
                }
                DocumentState.SetFile(file.Value.FileName, file.Value.ContentType, file.Value.Bytes);
            }

            _message = null;
            return;
        }

        if (DocumentState.FileBytes is null)
        {
            _message = "Sem ficheiro carregado. Volta ao upload.";
            return;
        }

        _message = null;
        _loadedFromHistory = false;
        _doc.Source = "Upload";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (DocumentState.FileBytes is null || string.IsNullOrWhiteSpace(DocumentState.ContentType))
            return;
        if (_loadedFromHistory)
            return;


        if (!(DocumentState.ContentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase)
           || DocumentState.ContentType.Equals("application/pdf", StringComparison.OrdinalIgnoreCase)))
            return;

        var b = DocumentState.FileBytes;
        var sig8 = string.Join("", b.Take(8).Select(x => x.ToString("X2")));
        var sig = $"{DocumentState.ContentType}|{b.Length}|{sig8}";

        if (sig == _lastAutoSig)
            return;

        _lastAutoSig = sig;

        await ReprocessQrAsync();
    }


    private readonly HashSet<string> _manuallyEditedFields = new(StringComparer.Ordinal);

    private Task OnFieldEditedAsync(string fieldName)
    {
        _manuallyEditedFields.Add(fieldName);
        return Task.CompletedTask;
    }

    private void SetIfNotEdited(string fieldName, Action setter)
    {
        if (_manuallyEditedFields.Contains(fieldName))
            return;

        setter();
    }

    private void ApplyQrTextField(string fieldName, Func<string> currentValue, Action<string> setValue, string? newValue)
    {
        if (_manuallyEditedFields.Contains(fieldName))
            return;

        var next = (newValue ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(next))
            return;

        var current = (currentValue() ?? string.Empty).Trim();
        if (string.Equals(current, next, StringComparison.Ordinal))
            return;

        setValue(next);
    }

    private static DateTime? TryParseQrDate(string? yyyymmdd)
    {
        if (string.IsNullOrWhiteSpace(yyyymmdd) || yyyymmdd.Length != 8) return null;
        if (!int.TryParse(yyyymmdd[..4], out var y)) return null;
        if (!int.TryParse(yyyymmdd.Substring(4, 2), out var m)) return null;
        if (!int.TryParse(yyyymmdd.Substring(6, 2), out var d)) return null;

        try { return new DateTime(y, m, d); }
        catch { return null; }
    }

    private static string ExtractSeriesFromG(string? g)
    {
        if (string.IsNullOrWhiteSpace(g)) return "";
        var parts = g.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2 ? parts[1] : "";
    }

    private static string ExtractNumberFromAtcud(string? h)
    {
        if (string.IsNullOrWhiteSpace(h)) return "";
        var idx = h.LastIndexOf('-');
        return (idx >= 0 && idx < h.Length - 1) ? h[(idx + 1)..] : "";
    }

    private void ApplyQrToLocalDocument(QrData d)
    {
        ApplyQrTextField(nameof(LocalDocument.IssuerTaxId), () => _doc.IssuerTaxId, v => _doc.IssuerTaxId = v, d.A);
        ApplyQrTextField(nameof(LocalDocument.DocumentType), () => _doc.DocumentType, v => _doc.DocumentType = v, d.D);
        ApplyQrTextField(nameof(LocalDocument.Series), () => _doc.Series, v => _doc.Series = v, ExtractSeriesFromG(d.G));
        ApplyQrTextField(nameof(LocalDocument.ATCUD), () => _doc.ATCUD, v => _doc.ATCUD = v, d.H);
        ApplyQrTextField(nameof(LocalDocument.DocumentNumber), () => _doc.DocumentNumber, v => _doc.DocumentNumber = v, ExtractNumberFromAtcud(d.H));

        var dt = TryParseQrDate(d.F);
        if (dt is not null)
            SetIfNotEdited(nameof(LocalDocument.DocumentDate), () => _doc.DocumentDate = dt.Value);

        _formKey++;
    }

    private void RunQrParseAndApply(string payload)
    {
        var parsed = QrParser.Parse(payload);
        QrDocs = new List<QrData> { parsed };

        QrJson = JsonSerializer.Serialize(QrDocs, new JsonSerializerOptions { WriteIndented = true });

        _doc.QrParsedData = JsonDocument.Parse(
            JsonSerializer.Serialize(parsed, new JsonSerializerOptions { WriteIndented = false })
        );

        ApplyQrToLocalDocument(parsed);
    }

    private async Task ReprocessQrAsync()
    {
        if (_readingQr) return;

        _readingQr = true;
        _qrCts?.Cancel();
        _qrCts = new CancellationTokenSource();

        var runId = ++_qrRunId;
        var token = _qrCts.Token;

        _message = "A ler QR...";
        await InvokeAsync(StateHasChanged);

        QrDecodedText = null;
        QrJson = null;
        QrDocs.Clear();

        try
        {
            if (DocumentState.FileBytes is null || string.IsNullOrWhiteSpace(DocumentState.ContentType))
            {
                _message = "Sem ficheiro carregado.";
                return;
            }
            var decode = await QrDecoder.DecodeAsync(
                DocumentState.FileBytes,
                DocumentState.ContentType,
                token);

            if (token.IsCancellationRequested || runId != _qrRunId)
                return;

            if (decode.Success)
            {
                var payload = (decode.Payload ?? string.Empty).Replace("\r", "").Replace("\n", "").Trim();
                _doc.QrRawPayload = payload;
                QrDecodedText = payload;

                RunQrParseAndApply(payload);

                _message = $"QR lido e campos preenchidos em {decode.DurationMs} ms ({decode.Strategy}, tentativas: {decode.Attempts}).";
            }
            else if (string.Equals(decode.Status, "CANCELLED", StringComparison.OrdinalIgnoreCase))
            {
                _message = "Leitura cancelada.";
            }
            else
            {
                _message = $"QR não encontrado ({decode.Strategy}, tentativas: {decode.Attempts}, {decode.DurationMs} ms).";
                return;
            }
        }
        catch (Exception ex)
        {
            _message = $"Erro a ler QR: {ex.Message}";
        }
        finally
        {
            if (runId == _qrRunId)
            {
                _readingQr = false;
                await InvokeAsync(StateHasChanged);
            }
        }
    }


    private async Task ReprocessQrCropAsync()
    {
        if (_readingQr) return;

        _readingQr = true;
        _qrCts?.Cancel();
        _qrCts = new CancellationTokenSource();

        var runId = ++_qrRunId;
        var token = _qrCts.Token;

        _message = "A ler QR (crop manual)...";
        await InvokeAsync(StateHasChanged);

        try
        {
            if (DocumentState.FileBytes is null || string.IsNullOrWhiteSpace(DocumentState.ContentType))
            {
                _message = "Sem ficheiro carregado.";
                return;
            }

            var decode = await QrDecoder.DecodeFromCropAsync(
                DocumentState.FileBytes,
                DocumentState.ContentType,
                _cropXPct,
                _cropYPct,
                _cropWPct,
                _cropHPct,
                token);

            if (token.IsCancellationRequested || runId != _qrRunId)
                return;

            if (decode.Success)
            {
                var payload = (decode.Payload ?? string.Empty).Replace("\r", "").Replace("\n", "").Trim();
                _doc.QrRawPayload = payload;
                QrDecodedText = payload;
                RunQrParseAndApply(payload);
                _message = $"QR lido via crop em {decode.DurationMs} ms.";
            }
            else if (string.Equals(decode.Status, "CANCELLED", StringComparison.OrdinalIgnoreCase))
            {
                _message = "Leitura cancelada.";
            }
            else
            {
                _message = "Não foi possível ler QR com este crop. Ajusta X/Y/Largura/Altura e tenta novamente.";
            }
        }
        catch (Exception ex)
        {
            _message = $"Erro no crop QR: {ex.Message}";
        }
        finally
        {
            if (runId == _qrRunId)
            {
                _readingQr = false;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private async Task SaveDraftAsync()
    {
        _message = null;

        var bytes = DocumentState.FileBytes;
        var fileName = DocumentState.FileName;
        var contentType = DocumentState.ContentType;

        if (bytes is null || string.IsNullOrWhiteSpace(fileName) || string.IsNullOrWhiteSpace(contentType))
        {
            _message = "Nenhum ficheiro em memória. Volta ao upload.";
            return;
        }

        _saving = true;
        try
        {
            _doc.FileKey = string.IsNullOrWhiteSpace(_doc.FileKey) ? $"doc:{_doc.Id:D}" : _doc.FileKey;
            _doc.SyncStatus = SyncStatus.PendingSync;

            await IndexedDb.SaveDocumentAsync(_doc, fileName, contentType, bytes);
            await SyncService.SyncPendingAsync();

            _message = "Rascunho guardado localmente (IndexedDB).";
        }
        catch (Exception ex)
        {
            _message = $"Erro ao guardar rascunho: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }
}
