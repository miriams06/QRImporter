@using Importer.Client.Services
@using Importer.Core.Config
@inject FeatureFlagsService Flags
@inject AppConfig Cfg
@inject SyncService Sync
@inject OnlineModeService OnlineMode

@* Só visível em Development *@
@if (!IsDev) { return; }

<div class="devtools">
    <div class="devtools-title">⚙️ Dev Tools</div>

    <div class="devtools-env">Ambiente: <strong>@Cfg.EnvironmentName</strong></div>

    <label class="devtools-row">
        <input type="checkbox" checked="@Flags.EffectiveOfflineMode" @onchange="OnOfflineChanged" />
        <span>Forçar Offline</span>
    </label>

    <label class="devtools-row">
        <input type="checkbox" checked="@Flags.EffectiveServerSyncEnabled" @onchange="OnSyncChanged" />
        <span>Sync com API</span>
    </label>

    <label class="devtools-row">
        <input type="checkbox" checked="@Flags.EffectiveQrReprocessingEnabled" @onchange="OnQrChanged" />
        <span>Reprocessar QR</span>
    </label>

    <label class="devtools-row">
        <input type="checkbox" checked="@Flags.EffectiveCameraEnabled" @onchange="OnCameraChanged" />
        <span>Câmara</span>
    </label>

    <label class="devtools-row">
        <input type="checkbox" checked="@Flags.EffectiveShowPerformanceMetrics" @onchange="OnPerfChanged" />
        <span>Métricas de Performance</span>
    </label>

    <button class="devtools-btn" @onclick="Reset">Repor Defaults</button>
    <button class="devtools-btn" @onclick="TryAutoSyncNowAsync">Sync Agora</button>
</div>

@code {
    private bool IsDev =>
        string.Equals(Cfg.EnvironmentName, "Development", StringComparison.OrdinalIgnoreCase);

    private async Task TryAutoSyncNowAsync()
    {
        if (!Flags.EffectiveServerSyncEnabled) return;
        if (!await OnlineMode.IsEffectivelyOnlineAsync()) return;
        await Sync.SyncPendingAsync();
    }

    private async Task OnOfflineChanged(ChangeEventArgs e)
    {
        Flags.Overrides.OfflineMode = (bool?)e.Value == true;
        await Flags.SaveAsync();
        if (!Flags.EffectiveOfflineMode) await TryAutoSyncNowAsync();
        StateHasChanged();
    }

    private async Task OnSyncChanged(ChangeEventArgs e)
    {
        Flags.Overrides.ServerSyncEnabled = (bool?)e.Value == true;
        await Flags.SaveAsync();
        if (Flags.EffectiveServerSyncEnabled) await TryAutoSyncNowAsync();
        StateHasChanged();
    }

    private async Task OnQrChanged(ChangeEventArgs e)
    {
        Flags.Overrides.QrReprocessingEnabled = (bool?)e.Value == true;
        await Flags.SaveAsync();
        StateHasChanged();
    }

    private async Task OnCameraChanged(ChangeEventArgs e)
    {
        Flags.Overrides.CameraEnabled = (bool?)e.Value == true;
        await Flags.SaveAsync();
        StateHasChanged();
    }

    private async Task OnPerfChanged(ChangeEventArgs e)
    {
        Flags.Overrides.ShowPerformanceMetrics = (bool?)e.Value == true;
        await Flags.SaveAsync();
        StateHasChanged();
    }

    private async Task Reset()
    {
        await Flags.ClearAsync();
        await TryAutoSyncNowAsync();
        StateHasChanged();
    }
}
