@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthState

@* 
    Componente de guarda de rota.
    Uso: envolver o conteúdo protegido com <RouteGuard> ... </RouteGuard>
    Redireciona para /login se não autenticado.
    Mostra "Acesso negado" se autenticado mas sem a role certa.
*@

@if (_checked)
{
    @if (_authorized)
    {
        @ChildContent
    }
    else if (_authenticated)
    {
        <div class="access-denied">
            <h3>Acesso negado</h3>
            <p>Não tens permissão para aceder a esta página.</p>
        </div>
    }
    @* Se não autenticado, já foi redireccionado — não renderizar nada *@
}

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Role mínima necessária. null = apenas autenticação.
    /// Valores: "Admin", "Operador", "Revisor"
    /// </summary>
    [Parameter] public string? RequiredRole { get; set; }

    private bool _checked;
    private bool _authenticated;
    private bool _authorized;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        var user = state.User;

        _authenticated = user.Identity?.IsAuthenticated == true;

        if (!_authenticated)
        {
            var returnUrl = Uri.EscapeDataString(Nav.Uri);
            Nav.NavigateTo($"/login?returnUrl={returnUrl}", forceLoad: false);
            _checked = true;
            return;
        }

        _authorized = RequiredRole is null || user.IsInRole(RequiredRole) ||
                      // Admin tem sempre acesso
                      user.IsInRole("Admin");

        _checked = true;
    }
}
