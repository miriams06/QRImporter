{
  "ApiConfig": {
    "StorageEndpoint": "minio:9000",
    "StorageBucket": "importer",
    "StorageAccessKey": "",
    "StorageSecretKey": "",
    "StorageUseSsl": false,
    "JwtSecret": "",
    "JwtIssuer": "importer-api",
    "JwtAudience": "importer-client",
    "JwtAccessTokenMinutes": 60,
    "JwtRefreshTokenDays": 30,
    "DatabaseConnectionString": "",
    "EnvironmentName": "Development"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "AllowedHosts": "*"
}
