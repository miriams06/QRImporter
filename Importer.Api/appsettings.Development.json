{
  "ApiConfig": {
    "StorageEndpoint": "localhost:9000",
    "StorageBucket": "importer",
    "StorageAccessKey": "minioadmin",
    "StorageSecretKey": "minioadmin",
    "StorageUseSsl": false,
    "JwtSecret": "importer-dev-secret-minimo-32-caracteres!!",
    "JwtIssuer": "importer-api",
    "JwtAudience": "importer-client",
    "JwtAccessTokenMinutes": 60,
    "JwtRefreshTokenDays": 30,
    "DatabaseConnectionString": "Host=localhost;Port=5432;Database=importer;Username=postgres;Password=postgres",
    "EnvironmentName": "Development"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq"
    ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ]
  }
}
